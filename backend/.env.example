ARK_API_KEY=
DOUBAO_API_KEY=
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-lite-260215
DOUBAO_API_TYPE=responses

APIMART_API_KEY=
APIMART_API_BASE=https://api.aishuch.com/v1/images/generations
APIMART_MODEL=gpt-image-2-official
APIMART_SIZE=auto
APIMART_RESOLUTION=1k
NAIL_TRYON_V2_SIZE=auto
NAIL_TRYON_V2_RESOLUTION=1k

SEEDDREAM_API_KEY=
SEEDDREAM_API_BASE=https://ark.cn-beijing.volces.com/api/v3/images/generations
SEEDDREAM_MODEL=doubao-seedream-5-0-260128
SEEDDREAM_SIZE=1K

# Meituan local account/session config.
# Keep the real values only in backend/.env or another local file.
# Option A: paste a Cookie header copied from your own logged-in browser session.
MEITUAN_COOKIE=
# Option B: point to a local JSON file with {"cookie":"..."} or Playwright storage_state cookies.
MEITUAN_SESSION_FILE=backend/.meituan_session.json
# Optional city id. Hangzhou is 50.
MEITUAN_CITY_ID=50
# Optional user id/uuid copied from an active Meituan session if available.
MEITUAN_USER_ID=
MEITUAN_UUID=
# Optional: local Meituan merchant/case snapshot for deterministic similar-style matching.
MEITUAN_STORE_SNAPSHOT=backend/mock_db/meituan_store_snapshot.local.json
# Live search is enabled by default. Set to 0 to disable network search.
MEITUAN_ENABLE_LIVE_SEARCH=1
MEITUAN_ENABLE_PLAYWRIGHT_SEARCH=1
MEITUAN_ENABLE_HTTP_FALLBACK=0
MEITUAN_PLAYWRIGHT_HEADLESS=1
MEITUAN_PLAYWRIGHT_TIMEOUT=12
MEITUAN_PLAYWRIGHT_PAGE_TIMEOUT=9000
MEITUAN_TIMEOUT=8
MEITUAN_DEFAULT_KEYWORD=美甲
MEITUAN_DEFAULT_LATITUDE=30.2084
MEITUAN_DEFAULT_LONGITUDE=120.212
# Keep 0 to open a stable Dianping search page for the exact store name.
# Set to 1 only if direct shop URLs work reliably in your logged-in browser.
MEITUAN_OPEN_DIRECT_SHOP=0
